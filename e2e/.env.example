# Copy to .env.e2e and fill in values before running tests
# Run tests with: npx playwright test --env-file=.env.e2e

# Base URL (defaults to http://localhost:5173 for local dev)
E2E_BASE_URL=https://beeshop.place

# Manager credentials (email login)
E2E_MANAGER_EMAIL=manager@beeshopsplace.com
E2E_MANAGER_PASSWORD=your-manager-password

# Staff PINs for each role
E2E_WAITRON_PIN=1234
E2E_WAITRON_NAME=Test Waitron
E2E_KITCHEN_PIN=5678
E2E_BAR_PIN=9012
E2E_GRILLER_PIN=3456
E2E_SUPERVISOR_PIN=7890

# Optional: a specific table name to use in order flow tests
E2E_TEST_TABLE=Table 21
